# ============================================================
#  PROD .env shabloni — serverda `.env` deb nusxalab to'ldiring
#  cp .env.production.example .env
# ============================================================

# App
APP_PORT=8001
APP_ENV=production
# APP_KEY — HMAC imzolar (signed URL: only-office, document signature).
# Lokaldagi qiymatni AYNAN saqlang (eski signed URL'lar buzilmasligi uchun).
APP_KEY=base64:Q3kT6ZdOrPJHXgz0ocuMcl4rB23xbuE427wE3swPJ5E=
# APP_URL — signed URL'lar bazasi. Prod domeningiz:
APP_URL=https://hrm-api.railway.uz

# OO_FILE_BASE_URL — OnlyOffice document server backend'ni shu URL orqali oladi.
# Prodда tashqi domen (DS konteyneri backendga shu manzilda ulanadi).
OO_FILE_BASE_URL=https://hrm-api.railway.uz

# Database (Laravel bilan AYNAN bir xil DB)
DB_HOST=
DB_PORT=5432
DB_NAME=hrm
DB_USER=
DB_PASSWORD=

# Auth
BCRYPT_ROUNDS=12

# i18n
DEFAULT_LANG=uz

# MinIO / S3 (prod endpoint)
MINIO_ACCESS_KEY=hrm-app
MINIO_SECRET_KEY=
MINIO_REGION=us-east-1
MINIO_BUCKET=hrm-media
MINIO_ENDPOINT=https://s3.jamacoder.uz

# HikCentral (HCP) — internal network (server shu tarmoqni ko'rishi shart)
HIK_CENTRAL_KEY=
HIK_CENTRAL_SECRET=
HIK_CENTRAL_URL=
SIGNATURE_SERVER=http://localhost:8090/

# Socket / Redis (laravel socket-server parity)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
SOCKET_REDIS_DB=2
# PRODДА bo'sh QOLDIRMANG — frontend VITE_SOCKET_SECRET bilan bir xil qiymat.
SOCKET_SECRET=

# Zoom (Server-to-Server OAuth)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_EVENT_SECRET=
